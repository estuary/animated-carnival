          },
          "message": {
            "type": "string"
          },
          "shard": {
            "$ref": "ops-shard-schema.json"
          },
          "ts": {
            "description": "Timestamp corresponding to the start of the transaction",
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
